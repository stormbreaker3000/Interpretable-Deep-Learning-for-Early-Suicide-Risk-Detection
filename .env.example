# Kaggle API credentials — used by setup.sh to download Suicide_Detection.csv
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Get your credentials at: https://www.kaggle.com → Account → Create New API Token
# .env is gitignored; never commit real credentials.

KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
